#include <stdio.h>

int main() {
    char str[100];
    int i=0, vowels=0, cons=0;

    printf("Enter a word: ");
    scanf("%s",str);

    while(str[i] != '\0')
    {
        if(str[i]=='a'||str[i]=='e'||str[i]=='i'||str[i]=='o'||str[i]=='u'||
           str[i]=='A'||str[i]=='E'||str[i]=='I'||str[i]=='O'||str[i]=='U')
            vowels++;
        else
            cons++;

        i++;
    }

    printf("Vowels = %d\n",vowels);
    printf("Consonants = %d\n",cons);

    return 0;
}
