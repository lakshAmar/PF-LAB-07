#include <stdio.h>

int main() {
    int a[10], freq[100]={0};
    int i;

    printf("Enter 10 IDs:\n");

    for(i=0;i<10;i++)
        scanf("%d",&a[i]);

    for(i=0;i<10;i++)
    {
        if(freq[a[i]]==0)
            freq[a[i]]++;
        else
            a[i] = -1;
    }

    printf("Updated Array: ");

    for(i=0;i<10;i++)
        printf("%d ",a[i]);

    return 0;
}
